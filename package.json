{
  "name": "disk-reaper",
  "version": "1.3.0",
  "description": "Find and delete the largest files and folders on your PC",
  "main": "main.js",
  "author": "EERIE",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:appx": "electron-builder --win appx"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "installed_apps.js",
      "processes.js",
      "services.js",
      "scanner.js",
      "startup.js",
      "sysinfo.js",
      "cleaner.js",
      "networking.js",
      "export.js",
      "scripts/**/*",
      "build/**/*",
      "!node_modules",
      "!dist",
      "!.git"
    ],
    "appId": "com.eerie.largefilefinder",
    "productName": "Disk Reaper",
    "copyright": "© 2025 EERIE",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "appx",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "appx": {
      "identityName": "20715EerieGoesD.DiskReaper",
      "publisher": "CN=A2A89A47-0B2B-4C32-B85C-9753888A9FFC",
      "publisherDisplayName": "EERIE",
      "applicationId": "DiskReaper",
      "displayName": "Disk Reaper",
      "backgroundColor": "#0a0a0c",
      "languages": ["en-US"]
    }
  }
}
