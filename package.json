{
  "name": "large-file-finder",
  "version": "1.0.0",
  "description": "Find and delete the largest files and folders on your PC",
  "main": "main.js",
  "author": "EERIE",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:appx": "electron-builder --win appx"  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.eerie.largefilefinder",
    "productName": "Large File Finder",
    "copyright": "© 2025 EERIE",
    "icon": "build/icon.ico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "appx",
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "appx": {
      "identityName": "EERIE.LargeFileFinder",
      "publisher": "CN=EERIE",
      "publisherDisplayName": "EERIE",
      "applicationId": "LargeFileFinder",
      "displayName": "Large File Finder",
      "backgroundColor": "#0a0a0c",
      "languages": [
        "en-US"
      ]
    }
  }
}
